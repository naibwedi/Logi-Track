<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - logirack</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/navBar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/logirack.styles.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <!-- Left-aligned Admin Dashboard -->
            <div class="d-flex">
                @if (User.IsInRole("Admin"))
                {
                <a class="nav-link text-dark" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
                }
            </div>

            <!-- Center-aligned Navbar Items -->
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="driverManagementDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Driver Management
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="driverManagementDropdown">
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="DriverManagment">Driver List</a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="CreateDriver">Create Driver</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="addNewTripDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Trip Managment
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="addNewTripDropdown">
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="AddNewTripByAdmin">Add new Trip</a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="TripDetails">Trip Details</a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="TripRequests">Trip Requests</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="" asp-action="">Invoice Generation</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="" asp-action="">Payment Management</a>
                    </li>
                </ul>
            </div>

            <!-- Right-aligned Logout -->
            <div class="d-flex">
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
